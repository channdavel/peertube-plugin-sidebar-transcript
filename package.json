{
  "name": "peertube-plugin-sidebar-transcript",
  "version": "1.0.4",
  "description": "Adds a transcript sidebar to PeerTube embeds",
  "author": "ULS",
  "homepage": "https://github.com/channdavel/peertube-plugin-sidebar-transcript",
  "bugs": "https://github.com/channdavel/peertube-plugin-sidebar-transcript/issues",
  "engine": {
    "peertube": ">=6.0.0"
  },
  "library": "./main.js",
  "scripts": {
    "build": "node ./scripts/build.js",
    "prepare": "npm run build"
  },
  "clientScripts": [
    {
      "script": "dist/common-client-plugin.js",
      "scopes": [
        "embed"
      ]
    }
  ],
  "css": [
    "dist/style.css"
  ],
  "staticDirs": {},
  "translations": {},
  "devDependencies": {
    "esbuild": "^0.14.36"
  },
  "dependencies": {
    "@plussub/srt-vtt-parser": "^2.0.5"
  }
}
